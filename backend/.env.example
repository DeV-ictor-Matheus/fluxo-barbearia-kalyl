# URL de conexão do Prisma com o Postgres (Supabase) — pooler (porta 6543)
DATABASE_URL=

# Conexão direta ao Postgres, sem pooler (porta 5432) — usada em migrations
DIRECT_URL=

# Segredo do JWT do Supabase (Auth) — valida os tokens no requireAuth
SUPABASE_JWT_SECRET=

# URL base do projeto Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=